<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcx.campus.mapper.RoleMenuMapper">
    <insert id="insert">
        INSERT INTO sys_role_menu (role_id, menu_id)
        VALUES (#{roleId}, #{menuId})
    </insert>
    <insert id="insertBatchRoleMenu">
        INSERT INTO sys_role_menu (role_id, menu_id)
        VALUES
        <foreach collection="menuIds" item="menuId" separator=",">
            (#{roleId}, #{menuId})
        </foreach>
    </insert>

    <select id="countRoleWithMenu" resultType="java.lang.Integer" parameterType="java.lang.Long">
        SELECT COUNT(1) FROM sys_role_menu WHERE menu_id = #{menuId}
    </select>
    <select id="selectByRoleId" resultType="com.lcx.campus.domain.RoleMenu">
        SELECT rm.role_id, rm.menu_id
        FROM sys_role_menu rm
        WHERE rm.role_id = #{roleId}
    </select>

    <delete id="deleteRoleMenu" parameterType="com.lcx.campus.domain.RoleMenu">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId} AND menu_id = #{menuId}
    </delete>

    <delete id="deleteRoleMenuByRoleId" parameterType="java.lang.Long">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>
    <delete id="deleteRoleMenuByMenuId">
        DELETE FROM sys_role_menu WHERE menu_id = #{menuId}
    </delete>
    <delete id="deleteRoleMenuByRoleIds">
        DELETE FROM sys_role_menu WHERE role_id IN
        <foreach collection="roleIds" item="roleId" separator=",">
            #{roleId}
        </foreach>
    </delete>
</mapper>
