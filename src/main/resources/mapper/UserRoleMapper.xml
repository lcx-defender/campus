<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcx.campus.mapper.UserRoleMapper">
    <insert id="insertBatch">
        INSERT INTO sys_user_role (user_id, role_id)
        VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{userId}, #{roleId})
        </foreach>
    </insert>
    <delete id="deleteByUserId">
        delete from sys_user_role
        where user_id = #{userId}
    </delete>
    <delete id="deleteByRoleId">
        delete from sys_user_role
        where role_id = #{roleId}
    </delete>

    <select id="selectRoleIdByUserId" resultType="java.lang.Long">
        select ur.role_id
        from sys_user_role ur
        where ur.user_id = #{userId}
    </select>
    <select id="selectByRoleId" resultType="com.lcx.campus.domain.UserRole">
        select ur.user_id, ur.role_id
        from sys_user_role ur
        where ur.role_id = #{roleId}
    </select>
    <select id="selectUserByRoleId" resultType="com.lcx.campus.domain.User">
        select u.*
        from sys_user_role ur
        left join sys_user u on ur.user_id = u.user_id
        where ur.role_id = #{roleId}
    </select>
</mapper>
